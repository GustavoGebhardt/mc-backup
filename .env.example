# Minecraft
MINECRAFT_DIR=/home/ubuntu/minecraft-server/world

# RCON — habilite no server.properties:
#   rcon.enable=true
#   rcon.port=25575
#   rcon.password=suasenha
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=changeme

# NFS
NFS_HOST=192.168.1.100
NFS_SHARE=/volume1/minecraft
NFS_MOUNT_POINT=/mnt/mc-backup

# Retenção estilo Proxmox (número de backups a manter por geração)
RETENTION_HOURLY=24
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=12

# Temporary local directory (deleted after upload)
BACKUP_TMP_DIR=/tmp/mc-backup

# Backup timeout in seconds (default: 2700 = 45 minutes)
BACKUP_TIMEOUT=2700

# Telegram (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
